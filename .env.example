# Copy this file to ".env" and fill in your key to enable the AI chat.
# The chat uses Moonshot AI's Kimi K2.6 via NVIDIA's OpenAI-compatible NIM API.
# Get a key at https://build.nvidia.com (open the Kimi K2.6 model -> "Get API Key").

NVIDIA_API_KEY=nvapi-...

# Optional: override the model. Default is moonshotai/kimi-k2.6
# CHAT_MODEL=moonshotai/kimi-k2.6
